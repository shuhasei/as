{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "game",
  "main": "src/index.js",
  "compatibility_date": "2026-07-23",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "GAME_ROOMS",
        "class_name": "GameRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["GameRoom"]
    }
  ]
}
